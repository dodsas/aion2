# Python 캐시
__pycache__/
*.py[cod]

# IDE
.idea/
*.iml

# 런타임 · 락 · 로그
.server.pid
.update.lock
logs/

# 시크릿 (Jenkins·Turso 접속정보 등 — 절대 커밋 금지)
.env
.env.*
# 예시 템플릿은 커밋한다 (git 은 라인 끝 주석 미지원 → 부정 패턴은 반드시 단독 줄)
!.env.example


# SQLite 임시 파일 (WAL 모드)
*.db-shm
*.db-wal

# 캐릭터 상세 캐시 DB (서버가 자동 생성 · 재생성 가능)
char_cache.db

# 로컬 상태 저장소 폴백 (Turso 미설정 시 server.py 가 자동 생성)
app_store.db

# 크롤 원본 스냅샷 (crawl_craft.py 로 재생성 가능 · 디버그용)
raw/

# 파티 복구 백업(로컬 보관용)
party_backup_*.json
