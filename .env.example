# ── 아이온2 뷰어 환경변수 ────────────────────────────────────────────
# 이 파일을 복사해 .env 로 만들고 값을 채운다:  cp .env.example .env
# (.env 는 절대 커밋되지 않는다 — .gitignore 처리됨)

# ── Turso (libSQL) 접속정보 ──────────────────────────────────────────
# 설정하면 서버가 모든 상태 데이터(캐릭터 상세 캐시 · 내 캐릭터/그룹 · 파티 모집 ·
# 숙제 프리셋 · 운영자 설정 · 보유량)를 Turso 에 저장한다. 비워두면 로컬
# SQLite 파일(app_store.db)로 폴백해 오프라인으로도 동작한다.
#
# 발급 방법 (Turso CLI):
#   curl -sSfL https://get.tur.so/install.sh | bash   # CLI 설치
#   turso auth signup                                  # 가입/로그인(무료)
#   turso db create aion2                              # DB 생성 (무료 플랜)
#   turso db show aion2 --url                           # → TURSO_DATABASE_URL
#   turso db tokens create aion2                        # → TURSO_AUTH_TOKEN
#
TURSO_DATABASE_URL=libsql://aion2-your-org.turso.io
TURSO_AUTH_TOKEN=

# ── 서버 바인딩 (선택) ───────────────────────────────────────────────
# Render 는 PORT 를 자동 주입하므로 배포 시엔 건드릴 필요 없다.
HOST=0.0.0.0
PORT=8770
